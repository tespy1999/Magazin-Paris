<Window x:Class="MagazinParis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laborator 7 - Adăugare Produs" Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Titlu -->
            <RowDefinition Height="Auto"/> <!-- Cod -->
            <RowDefinition Height="Auto"/> <!-- Nume -->
            <RowDefinition Height="Auto"/> <!-- Pret -->
            <RowDefinition Height="Auto"/> <!-- Cantitate -->
            <RowDefinition Height="Auto"/> <!-- Mesaj Eroare -->
            <RowDefinition Height="Auto"/> <!-- Butoane -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="ADĂUGARE PRODUS NOU" 
                   FontSize="20" FontWeight="Bold" Foreground="#2F3640" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Cod Unic -->
        <Label x:Name="lblCod" Grid.Row="1" Grid.Column="0" Content="Cod Unic:" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="txtCod" Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBoxStyle}"/>

        <!-- Nume -->
        <Label x:Name="lblNume" Grid.Row="2" Grid.Column="0" Content="Nume Produs:" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="txtNume" Grid.Row="2" Grid.Column="1" Style="{StaticResource TextBoxStyle}"/>

        <!-- Pret -->
        <Label x:Name="lblPret" Grid.Row="3" Grid.Column="0" Content="Preț (RON):" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="txtPret" Grid.Row="3" Grid.Column="1" Style="{StaticResource TextBoxStyle}"/>

        <!-- Cantitate -->
        <Label x:Name="lblCantitate" Grid.Row="4" Grid.Column="0" Content="Cantitate (Stoc):" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="txtCantitate" Grid.Row="4" Grid.Column="1" Style="{StaticResource TextBoxStyle}"/>

        <!-- Mesaj de eroare -->
        <TextBlock x:Name="txtMesajEroare" Grid.Row="5" Grid.ColumnSpan="2" 
                   Foreground="Red" FontSize="12" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,10" Visibility="Collapsed"/>

        <!-- Butoane -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnAdauga" Content="Adaugă" Width="100" Height="30" Margin="5" 
                    IsDefault="True" Click="btnAdauga_Click" Background="#44BD32" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnAnuleaza" Content="Anulează" Width="100" Height="30" Margin="5" 
                    IsCancel="True" Click="btnAnuleaza_Click" Background="#EA2027" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
