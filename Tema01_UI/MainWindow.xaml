<Window x:Class="MagazinParis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laborator 8 - Gestiune Magazin Paris" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- Stiluri comune (Bonus) -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="5,2,5,2"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5,2,5,2"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Meniu (Cerința 1) -->
        <Menu DockPanel.Dock="Top" Background="White">
            <MenuItem Header="_Fișier">
                <MenuItem Header="_Salvează" Click="btnSalveaza_Click"/>
                <Separator />
                <MenuItem Header="_Ieșire" Click="btnIesire_Click"/>
            </MenuItem>
            <MenuItem Header="_Ajutor">
                <MenuItem Header="_Despre" Click="btnDespre_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/> <!-- Lățime fixă pentru formular -->
                <ColumnDefinition Width="*"/>   <!-- Lățime flexibilă pentru tabel (Responsive) -->
            </Grid.ColumnDefinitions>

            <!-- Coloana 1: Formular Adăugare -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Adăugare Produs" Style="{StaticResource HeaderTextStyle}"/>

                        <Label x:Name="lblCod" Content="Cod Unic:"/>
                        <TextBox x:Name="txtCod" Margin="0,0,0,10"/>

                        <Label x:Name="lblNume" Content="Nume Produs:"/>
                        <TextBox x:Name="txtNume" Margin="0,0,0,10"/>

                        <Label Content="Preț:"/>
                        <TextBox x:Name="txtPret" Margin="0,0,0,10"/>

                        <Label Content="Cantitate:"/>
                        <TextBox x:Name="txtCantitate" Margin="0,0,0,10"/>

                        <!-- RadioButtons pentru Categorie (Cerința 3) -->
                        <Label Content="Categorie (Selecție unică):" FontWeight="Bold" Margin="0,10,0,5"/>
                        <StackPanel x:Name="pnlCategorii">
                            <RadioButton Content="Patiserie" IsChecked="True" Tag="Patiserie"/>
                            <RadioButton Content="Băuturi" Tag="Bauturi"/>
                            <RadioButton Content="Dulciuri" Tag="Dulciuri"/>
                            <RadioButton Content="Gustări" Tag="Gustari"/>
                        </StackPanel>

                        <!-- CheckBoxes pentru Caracteristici (Cerința 3) -->
                        <Label Content="Caracteristici (Selecție multiplă):" FontWeight="Bold" Margin="0,10,0,5"/>
                        <WrapPanel x:Name="pnlCaracteristici">
                            <CheckBox Content="Bio" Tag="Bio"/>
                            <CheckBox Content="Vegan" Tag="Vegan"/>
                            <CheckBox Content="Fără Zahăr" Tag="FaraZahar"/>
                            <CheckBox Content="Fără Gluten" Tag="FaraGluten"/>
                        </WrapPanel>

                        <Button Content="Adaugă în listă" Click="btnAdauga_Click" 
                                Background="#1A73E8" Foreground="White" Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Coloana 2: Căutare și Tabel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Zonă Căutare -->
                    <RowDefinition Height="*"/>    <!-- Tabel (Responsive) -->
                </Grid.RowDefinitions>

                <!-- Zonă de Căutare (Cerința 4) -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Caută după nume:" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtCautare" Width="200" Margin="10,0,10,0" VerticalAlignment="Center" 
                                 TextChanged="txtCautare_TextChanged"/>
                        <TextBlock Text="🔍" VerticalAlignment="Center" FontSize="16"/>
                    </StackPanel>
                </Border>

                <!-- Tabel Produse (DataGrid) -->
                <DataGrid x:Name="dgProduse" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" Background="White" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cod" Binding="{Binding CodUnic}" Width="60"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*"/>
                        <DataGridTextColumn Header="Preț" Binding="{Binding Pret, StringFormat={}{0:N2} RON}" Width="100"/>
                        <DataGridTextColumn Header="Categorie" Binding="{Binding Categorie}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
