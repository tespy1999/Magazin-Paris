<Window x:Class="MagazinParis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laborator 9 - Gestiune Magazin Paris" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="White">
            <MenuItem Header="_Fișier">
                <MenuItem Header="_Salvează" Click="btnSalveaza_Click"/>
                <Separator />
                <MenuItem Header="_Ieșire" Click="btnIesire_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Coloana 1: Formular Adăugare/Editare -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Detalii Produs" Style="{StaticResource HeaderTextStyle}"/>

                        <!-- ComboBox pentru Modificare (Cerința 2) -->
                        <Label Content="Selectează Produs pentru Editare:" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbSelectieProdus" Margin="0,0,0,15" 
                                  DisplayMemberPath="Nume"
                                  SelectionChanged="cmbSelectieProdus_SelectionChanged"
                                  IsEditable="True" IsTextSearchEnabled="True"/>

                        <Label x:Name="lblCod" Content="Cod Unic:"/>
                        <TextBox x:Name="txtCod" Margin="0,0,0,10"/>

                        <Label x:Name="lblNume" Content="Nume Produs:"/>
                        <TextBox x:Name="txtNume" Margin="0,0,0,10"/>

                        <Label Content="Preț:"/>
                        <TextBox x:Name="txtPret" Margin="0,0,0,10"/>

                        <Label Content="Cantitate:"/>
                        <TextBox x:Name="txtCantitate" Margin="0,0,0,10"/>

                        <!-- DatePicker (Cerința 1) -->
                        <Label Content="Data Adăugării:"/>
                        <DatePicker x:Name="dpDataAdaugarii" Margin="0,0,0,10"/>

                        <!-- ListBox pentru Categorie (Cerința 1) -->
                        <Label Content="Categorie (ListBox):" FontWeight="Bold"/>
                        <ListBox x:Name="lstCategorii" Height="80" Margin="0,0,0,10" SelectionMode="Single"/>

                        <!-- Caracteristici (CheckBoxes rămân din Lab 8) -->
                        <Label Content="Caracteristici:" FontWeight="Bold"/>
                        <WrapPanel x:Name="pnlCaracteristici">
                            <CheckBox Content="Bio" Tag="Bio"/>
                            <CheckBox Content="Vegan" Tag="Vegan"/>
                            <CheckBox Content="Fără Zahăr" Tag="FaraZahar"/>
                            <CheckBox Content="Fără Gluten" Tag="FaraGluten"/>
                        </WrapPanel>

                        <UniformGrid Columns="2" Margin="0,20,0,0">
                            <Button Content="Adaugă Nou" Click="btnAdauga_Click" Background="#1A73E8" Foreground="White"/>
                            <Button x:Name="btnModifica" Content="Modifică" Click="btnModifica_Click" Background="#F4B400" Foreground="White"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Coloana 2: Căutare și Tabel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Caută după nume:" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtCautare" Width="200" Margin="10,0,10,0" VerticalAlignment="Center" 
                                 TextChanged="txtCautare_TextChanged"/>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="dgProduse" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" Background="White" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cod" Binding="{Binding CodUnic}" Width="60"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*"/>
                        <DataGridTextColumn Header="Preț" Binding="{Binding Pret, StringFormat={}{0:N2} RON}" Width="80"/>
                        <DataGridTextColumn Header="Categorie" Binding="{Binding Categorie}" Width="100"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataAdaugarii, StringFormat={}{0:dd.MM.yyyy}}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
