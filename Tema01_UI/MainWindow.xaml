<Window x:Class="MagazinParis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laborator 1 - Detalii Produs" Height="350" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"> <!-- Culoare Hex pentru fundal -->

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
        
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}" />
            <Setter Property="Margin" Value="10,2,10,2" />
        </Style>

        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#E74C3C" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,20,0,20" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="30">
        <TextBlock Text="DETALII PRODUS" Style="{StaticResource TitleStyle}"/>

        <StackPanel Orientation="Horizontal">
            <Label Content="Nume:" FontWeight="Bold"/>
            <Label Content="{Binding Nume}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
            <Label Content="Cod:" FontWeight="Bold"/>
            <Label Content="{Binding CodUnic}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
            <Label Content="Pret:" FontWeight="Bold"/>
            <Label Content="{Binding Pret}"/>
            <Label Content="RON"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
            <Label Content="Stoc:" FontWeight="Bold"/>
            <Label Content="{Binding Cantitate}"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal">
            <Label Content="Categorie:" FontWeight="Bold"/>
            <Label Content="{Binding Categorie}"/>
        </StackPanel>
    </StackPanel>
</Window>
